{
	"name": "finsheet",
	"version": "0.2.0",
	"description": "A headless-leaning React grid for financial statements — sticky headers, tabular numerics, subtotal/total rows, and three edit modes.",
	"keywords": [
		"react",
		"grid",
		"table",
		"datagrid",
		"finance",
		"financial-statements",
		"tabular"
	],
	"license": "MIT",
	"contributors": [
		"finsheet contributors (https://github.com/joaquimserafim/finsheet/graphs/contributors)"
	],
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/joaquimserafim/finsheet.git"
	},
	"homepage": "https://github.com/joaquimserafim/finsheet#readme",
	"bugs": "https://github.com/joaquimserafim/finsheet/issues",
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsup",
		"dev": "vite",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:browser": "vitest run -c vitest.browser.config.ts",
		"bench": "vitest run -c vitest.bench.config.ts",
		"screenshots": "vitest run -c vitest.screenshots.config.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"prepare": "husky",
		"prepublishOnly": "pnpm build"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.10.0",
			"onFail": "download"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/browser": "^4.1.10",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"happy-dom": "^20.10.6",
		"husky": "^9.1.7",
		"playwright": "^1.61.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.10",
		"vitest-browser-react": "^2.2.0"
	}
}
